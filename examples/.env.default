# Quanscient Allsolve API credentials
# Create an Organization API key via the Allsolve web UI:
#   Settings > Organization > API keys > "Create key"
#
# Copy this file to .env and replace the placeholder values.

ALLSOLVE_ACCESS_KEY=your-access-key-here
ALLSOLVE_SECRET_KEY=your-secret-key-here
ALLSOLVE_HOST=https://allsolve.quanscient.com/
